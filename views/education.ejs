<%- include('partials/header') %>

<div class="page-header">
  <div class="page-eyebrow">My Journey</div>
  <h1 class="page-title">Education &amp; <em>Qualifications</em></h1>
  <p class="page-subtitle">Academic foundations and professional certifications that shape my craft.</p>
</div>

<!-- Education Timeline -->
<section class="section" style="background:var(--cream)">
  <div style="display:grid;grid-template-columns:1.1fr 0.9fr;gap:5rem;align-items:start">

    <div>
      <div class="section-label">Academic</div>
      <h2 class="section-title" style="margin-bottom:2rem">Degrees &amp; <em>Study</em></h2>
      <div class="timeline">
        <% education.forEach((item, i) => { %>
        <div class="timeline-item" style="transition-delay:<%= i*0.15 %>s">
          <div class="timeline-dot"></div>
          <div class="timeline-year"><%= item.year %></div>
          <div class="timeline-title"><%= item.title %></div>
          <div class="timeline-inst"><%= item.institution %></div>
          <span class="timeline-grade"><%= item.grade %></span>
          <p class="timeline-desc"><%= item.desc %></p>
        </div>
        <% }) %>
      </div>
    </div>

    <!-- Quote + Stats -->
    <div class="reveal-right">
      <div style="background:var(--charcoal);padding:2.5rem;position:relative;margin-bottom:1.5rem">
        <div style="font-family:var(--serif);font-size:5rem;line-height:.7;color:var(--gold);opacity:.35;position:absolute;top:1rem;left:1.5rem">"</div>
        <blockquote style="font-family:var(--serif2);font-size:1.1rem;font-style:italic;line-height:1.75;color:var(--gold-pale);position:relative;z-index:1;padding-top:.8rem">
          Education is not the filling of a pail, but the lighting of a fire.
        </blockquote>
        <p style="margin-top:1rem;font-size:.75rem;letter-spacing:.15em;text-transform:uppercase;color:var(--muted)">— W.B. Yeats</p>
      </div>
      <div style="background:var(--warm-white);border:1px solid rgba(201,146,42,.15);padding:1.8rem">
        <p style="font-size:.72rem;letter-spacing:.15em;text-transform:uppercase;color:var(--muted);margin-bottom:1.2rem">Quick Stats</p>
        <div style="display:flex;flex-direction:column;gap:.8rem">
          <% const stats = [['Graduation','2023'],['Specialisation','Software Engineering'],['Final Year Project','Real-Time Collab Platform'],['Achievement','Department Honours']] %>
          <% stats.forEach(([k,v]) => { %>
          <div style="display:flex;justify-content:space-between;font-size:.85rem;border-bottom:1px solid rgba(201,146,42,.1);padding-bottom:.65rem">
            <span style="color:var(--muted)"><%= k %></span>
            <span style="color:var(--charcoal);font-weight:500"><%= v %></span>
          </div>
          <% }) %>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Certifications -->
<section class="section section-dark">
  <div class="section-label">Certified</div>
  <h2 class="section-title">Professional <em>Certifications</em></h2>
  <div class="grid-3" style="margin-top:0">
    <% certifications.forEach((cert, i) => { %>
    <div class="cert-card reveal" style="transition-delay:<%= i*0.1 %>s">
      <div class="cert-icon-box"><%= cert.icon %></div>
      <div class="cert-info">
        <h4><%= cert.title %></h4>
        <p><%= cert.issuer %> · <%= cert.year %></p>
      </div>
    </div>
    <% }) %>
  </div>
</section>

<!-- Currently Learning -->
<section class="section" style="background:var(--warm-white)">
  <div class="section-label">Always Growing</div>
  <h2 class="section-title">Currently <em>Learning</em></h2>
  <div class="grid-3" style="margin-top:0">
    <% const learning = [
      {icon:'🦀', title:'Rust', desc:'Systems-level programming for performance-critical services and WebAssembly targets.'},
      {icon:'🤖', title:'LLM Integration', desc:'Building AI-powered features using OpenAI, Anthropic APIs, and RAG architectures.'},
      {icon:'☸️', title:'Kubernetes at Scale', desc:'Advanced cluster management, Helm charts, and GitOps workflows with ArgoCD.'}
    ] %>
    <% learning.forEach(l => { %>
    <div class="reveal" style="border:1px solid rgba(201,146,42,.18);padding:1.8rem;background:var(--cream);transition:transform .3s,box-shadow .3s"
      onmouseenter="this.style.transform='translateY(-4px)';this.style.boxShadow='0 12px 32px rgba(60,40,20,.1)'"
      onmouseleave="this.style.transform='';this.style.boxShadow=''">
      <div style="font-size:2rem;margin-bottom:.8rem"><%= l.icon %></div>
      <h3 style="font-family:var(--serif);font-size:1.1rem;font-weight:700;color:var(--charcoal);margin-bottom:.5rem"><%= l.title %></h3>
      <p style="font-size:.83rem;line-height:1.7;color:var(--muted)"><%= l.desc %></p>
      <div style="margin-top:1rem;display:flex;align-items:center;gap:.5rem">
        <div style="flex:1;height:3px;background:rgba(201,146,42,.12);border-radius:2px">
          <div style="height:100%;width:40%;background:var(--gold);border-radius:2px"></div>
        </div>
        <span style="font-size:.68rem;color:var(--gold);letter-spacing:.08em">In Progress</span>
      </div>
    </div>
    <% }) %>
  </div>
</section>

<%- include('partials/footer') %>
